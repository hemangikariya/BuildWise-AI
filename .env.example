# Application Settings
PROJECT_NAME="BuildWise AI"
SECRET_KEY="SUPER_SECRET_DEVELOPMENT_KEY_CHANGE_IN_PRODUCTION"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Allowed Origins (comma-separated list)
BACKEND_CORS_ORIGINS="http://localhost:3000"

# Database Configuration (PostgreSQL only)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=buildwise
POSTGRES_PORT=5432

# Redis Configuration (Optional / Core Rate Limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# LLM Selection ("gemini" or "openai")
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-pro

# API Keys (Provide at least one based on LLM_PROVIDER choice)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# RAG & Chroma Settings
CHROMA_PERSIST_DIRECTORY="./chroma_db"
EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"
KNOWLEDGE_BASE_DIR="./docs"
